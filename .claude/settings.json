{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(./**)",
      "Write(./**)",
      "Edit(./**)",
      "Bash(./install.sh)",
      "Bash(bash install.sh)",
      "Bash(mkdir:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(date:*)",
      "Bash(open ./dashboard/index.html)"
    ],
    "deny": [
      "Write(../**)",
      "Edit(../**)",
      "Bash(rm -rf:*)",
      "Bash(curl:*)",
      "Bash(sudo:*)"
    ]
  }
}
